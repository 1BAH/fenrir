#! /bin/bash

[ -n "$SUDO_USER" ] && user=$SUDO_USER || user=$USER

update=""

###################################################################

GREEN="\033[38;5;112m"
BLUE="\033[38;5;4m"
YELLOW="\033[38;5;214m"
RED="\033[38;5;196m"
ENDC="\033[0m"


function info {
    [ -z "$update" ] && echo -e "${BLUE}[ INFO  ]${ENDC} $*" # > /dev/tty
}

function warn {
    [ -z "$update" ] && echo -e "${YELLOW}[WARNING]${ENDC} $*" # > /dev/tty
}

function err {
    [ -z "$update" ] && echo -e "${RED}[ ERROR ]${ENDC} $*" # > /dev/tty
}

function succ {
    [ -z "$update" ] && echo -e "${GREEN}[SUCCESS]${ENDC} $*" # > /dev/tty
}

#################################################################

if [ "$1" = "update" ]; then
    info "Uninstalling previous version of fenrir: $(jq '.version' '/etc/fenrir/main.json')"
    update=true
fi

#################################################################

if [ "$(id -u)" -ne 0 ]; then
    err "The script must be run under sudo!"
    exit 111
fi

#################################################################

info "Removing '/etc/fenrir'.."

rm -r /etc/fenrir

succ "Done"

#################################################################

info "Removing '/var/fenrir'.."

rm -r /var/fenrir

succ "Done"

#################################################################

info "Removing core.."

for cmd in /usr/local/bin/fenrir-*; do
    name=$(basename "$cmd")

    if ! rm "/usr/local/bin/$name"; then
        err "Terminating.."
        exit 10
    fi
done

succ "Done"

#################################################################

info "Removing basic utils.."

if ! rm -r "/home/$user/.fenrir"; then
    err "Terminating .."
    exit 10
fi

succ "Done"

#################################################################

info "Removing cli tool .."

[ -z "$update" ] && rm "/usr/local/bin/fenrir"

succ "Done"
