#! /bin/bash

[ -n "$SUDO_USER" ] && user=$SUDO_USER || user=$USER

update=""

###################################################################

GREEN="\033[38;5;112m"
BLUE="\033[38;5;4m"
YELLOW="\033[38;5;214m"
RED="\033[38;5;196m"
ENDC="\033[0m"


function info {
    [ -z "$update" ] && echo -e "${BLUE}[ INFO  ]${ENDC} $*" # > /dev/tty
}

function warn {
    [ -z "$update" ] && echo -e "${YELLOW}[WARNING]${ENDC} $*" # > /dev/tty
}

function err {
    [ -z "$update" ] && echo -e "${RED}[ ERROR ]${ENDC} $*" # > /dev/tty
}

function succ {
    [ -z "$update" ] && echo -e "${GREEN}[SUCCESS]${ENDC} $*" # > /dev/tty
}

#################################################################

if [ "$1" = "update" ]; then
    info "Uninstalling previous version of fenrir: $(jq '.version' '/etc/fenrir/main.json')"
    update=true
fi

if [ "$1" = "docker" ]; then
    echo "[ INFO  ] Uninstalling previous version of fenrir: $(jq '.version' '/etc/fenrir/main.json')"
    update=true
fi

#################################################################

if [ "$(id -u)" -ne 0 ]; then
    err "The script must be run under sudo!"
    exit 111
fi

#################################################################

info "Removing '/etc/fenrir'.."

if [ -d "/etc/fenrir" ]; then
    rm -r /etc/fenrir
else
    warn "The directory does not exist!"
fi

succ "Done"

#################################################################

info "Removing '/var/fenrir'.."

if [ -d "/var/fenrir" ]; then
    rm -r /var/fenrir
else
    warn "The directory does not exist!"
fi

succ "Done"

#################################################################

info "Removing core.."

for cmd in /usr/local/bin/fenrir-*; do
    if [ "$cmd" = "/usr/local/bin/fenrir-*" ]; then
        warn "No core commands were found!"
        break
    fi

    name=$(basename "$cmd")

    if ! rm "/usr/local/bin/$name"; then
        err "Terminating.."
        exit 10
    fi
done

succ "Done"

#################################################################

info "Removing basic utils.."

if [ -d "/home/$user/.fenrir/custom" ]; then
    if ! rm -r "/home/$user/.fenrir/custom"; then
        err "Terminating .."
        exit 10
    fi
else
    warn "fenrir's local repository was not found!"
fi

succ "Done"

#################################################################

info "Removing additional .."

if [ -z "$update" ]; then
    if [ -f "/usr/local/bin/update-fenrir" ]; then
        rm "/usr/local/bin/update-fenrir"
    fi
fi

succ "Done"

#################################################################

info "Removing cli tool .."

if [ -z "$update" ]; then
    if [ -f "/usr/local/bin/fenrir" ]; then
        rm "/usr/local/bin/fenrir"
    else
        warn "fenrir cli is not installed"
    fi
fi

succ "Done"

