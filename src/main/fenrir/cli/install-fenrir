#! /usr/bin/env bash

#shopt -s globstar

CLI_DIR=$(dirname "$(realpath "$0")")
CORE_UTILS_DIR=$(realpath "${CLI_DIR}/../core")
CFGS_DIR=$(realpath "${CLI_DIR}/../configs")
BASIC_UTILS_DIR=$(realpath "${CLI_DIR}/../custom")

while IFS='=' read -r key value; do
    if [ "$key" = "version" ]; then
        VERSION=$value
    fi
done < "$CLI_DIR/fenrir.properties"

update=""
docker_update=""
v="-v"

###################################################################

pushd "$CORE_UTILS_DIR" &> /dev/null

cd loki

./install.loki

sudo mv /tmp/FENRIR_HEADER /usr/local/bin/loki
sudo chmod +x /usr/local/bin/loki

source /usr/local/bin/loki

popd &> /dev/null

#################################################################

if [ "$1" = "update" ]; then
    loki-log info "$v" "Updating fenrir up to version @$VERSION"
    update=true
fi

if [ "$1" = "docker" ]; then
    echo "[ INFO  ] Updating fenrir up to the latest version: \"$VERSION\""
    update=true
    docker_update=true
    v=""
fi

#################################################################

if [ "$(id -u)" -ne 0 ]; then
    if [ -n "$update" ]; then
        loki-log err "$v" "THIS SHOULD NOT HAVE HAPPENED! CONTACT US!"
    fi

    loki-log err "$v" "The script must be run under sudo!"
    exit 111
fi

###################################################################

[ -n "$SUDO_USER" ] && user=$SUDO_USER || user=$USER
loki-log info "$v" "Installing fenrir @$VERSION for '$user' user"

#################################################################

loki-log info "$v" "> Identifying OS.."

case "$(uname -s)" in
    Linux*)
        os_pref_home="/home"
        loki-log info "$v" ">> OS is LINUX"
    ;;
    Darwin*)
        os_pref_home="/Users"
        loki-log info "$v" ">> OS is MACOS"
    ;;
#    CYGWIN*)
#        os=Cygwin
#    ;;
#    MINGW*)
#        os=MinGw
#    ;;
#    MSYS_NT*)
#        os=MSys
#    ;;
    *)
        loki-log warn "$v" ">> Unsupported OS: '$(uname -s)'"
        loki-log warn "$v" ">> Do you agree to continue? (Potentially dangerous) [yes|no]"
        read -r op

        if [ "$op" != "yes" ]; then
            loki-log err "$v" "Terminating.."
            exit 3
        fi
    ;;
esac

#################################################################

loki-log info "$v" "> Validating environment.."

if [ -d "/etc/fenrir" ]; then
    loki-log warn "$v" ">> Directory '/etc/fenrir' already exists"
    loki-log warn "$v" ">> Remove existing '/etc/fenrir' [yes|no]"
    read -r op

    if [ "$op" = "yes" ]; then
        loki-log info "$v" ">>> Removing '/etc/fenrir'.."
        rm -fr /etc/fenrir
    else
        loki-log err "$v" "Terminating.."
        exit 3
    fi
fi

if [ -d "/var/fenrir" ]; then
    loki-log warn "$v" ">> Directory '/var/fenrir' already exists. Run uninstaller to remove it"
    loki-log warn "$v" ">> Remove existing '/var/fenrir'? [yes|no]"
    read -r op

    if [ "$op" = "yes" ]; then
        loki-log info "$v" ">>> Removing '/var/fenrir'.."
        rm -fr /var/fenrir
    else
        loki-log err "$v" "Terminating.."
        exit 3
    fi
fi

if ! type jq &> /dev/null; then
    loki-log err "$v" ">> 'jq' is not installed"
    exit 4
fi

if ! type wget &> /dev/null; then
    loki-log err "$v" ">> 'wget' is not installed"
    exit 4
fi

for cmd in "$CORE_UTILS_DIR"/*; do
    if ! [ -f "$cmd" ]; then
        continue
    fi

    name=$(basename "$cmd")

    if type "$name" &> /dev/null; then
        location=($(type "$name")) # FIXME: SC2207
        if [ -n "$docker_update" ]; then
            continue
        fi

        loki-log warn "$v" ">> Command <$name> already exists: '${location[2]}'"
        loki-log warn "$v" ">> After installation it will be overridden. Continue? [yes|no]"
        read -r op

        if [ "$op" != "yes" ]; then
            loki-log err "$v" "Terminating.."
            exit 3
        fi
    fi
done

loki-log succ "$v" "> Ready to be installed!"

#################################################################

loki-log info "$v" "> Creating '/etc/fenrir'.."

mkdir -p /etc/fenrir
chown "$user" /etc/fenrir

loki-log succ "$v" "> Done"

#################################################################

loki-log info "$v" "> Creating '/var/fenrir'.."

mkdir -p /var/fenrir
chown "$user" /var/fenrir

loki-log succ "$v" "> Done"

#################################################################

loki-log info "$v" "> Installing core.."

for cmd in "$CORE_UTILS_DIR"/*; do
    name=$(basename "$cmd")

    if [ -d "$cmd" ]; then
        continue
    fi

    if ! cp "$cmd" "/usr/local/bin/$name"; then
        loki-log err "$v" "Terminating.."
        exit 10
    fi
done

loki-log succ "$v" "> Done"

#################################################################

loki-log info "$v" "> Setting all configs.."

for cfg in "$CFGS_DIR"/*; do
    name=$(basename "$cfg")

    if ! {
        cp "$cfg" "/etc/fenrir/$name" &&
        chown "$user" "/etc/fenrir/$name"
    }; then
        loki-log err "$v" "Terminating.."
        exit 10
    fi
done

sudo chmod -t /tmp
jq ".version = \"$VERSION\"" "/etc/fenrir/main.json" > /tmp/INSTALL_FENRIR
cat /tmp/INSTALL_FENRIR > "/etc/fenrir/main.json"
sudo chmod +t /tmp

loki-log succ "$v" "> Done"

#################################################################

loki-log info "$v" "> Installing basic utils.."

if ! mkdir -p "$os_pref_home/$user/.fenrir/custom/walk"; then
    loki-log err "$v" "> Unable to create local storage"
    exit 189
fi

chown "$user" "$os_pref_home/$user/.fenrir"
chown "$user" "$os_pref_home/$user/.fenrir/custom"
chown "$user" "$os_pref_home/$user/.fenrir/custom/walk"

for util in "$BASIC_UTILS_DIR"/* "$BASIC_UTILS_DIR"/**/*; do
    relative_path=${util#$BASIC_UTILS_DIR/}

    if [ -d "$util" ]; then
        continue
    fi

    if ! {
        cp "$util" "$os_pref_home/$user/.fenrir/custom/$relative_path" &&
        chown "$user" "$os_pref_home/$user/.fenrir/custom/$relative_path"
    }; then
        loki-log err "$v" "Terminating.."
        exit 10
    fi
done

loki-log succ "$v" "> Done"

###################################################################

loki-log info "$v" "> Installing cli tool.."

cat "$CLI_DIR/fenrir" > "/usr/local/bin/fenrir"
chmod +x "/usr/local/bin/fenrir"

loki-log succ "$v" "> Done"

###################################################################

loki-log info "$v" "> Installing autocompletion.."

cp "`which fenrir-autocomplete`" "/etc/bash_completion.d/"

loki-log warn "$v" "> Run 'source ~/.bashrc' or reload terminal to apply autocompletion"

loki-log succ "$v" "> Done"

###################################################################

loki-log info "$v" "> Installing uninstaller.."

if ! {
    cp "$CLI_DIR/uninstall-fenrir" "/usr/local/bin/uninstall-fenrir" &&
    chmod +x "/usr/local/bin/uninstall-fenrir"
}; then
    loki-log err "$v" "Terminating.."
    exit 19
fi

loki-log succ "$v" "> Done"

###################################################################

update="" # Unmute

[ -z "$docker_update" ] && loki-log succ "$v" "Installation has finished!"
