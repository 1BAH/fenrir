#! /bin/bash

CLI_DIR=$(dirname "$(realpath "$0")")
CORE_UTILS_DIR=$(realpath "${CLI_DIR}/../core")
CFGS_DIR=$(realpath "${CLI_DIR}/../configs")
BASIC_UTILS_DIR=$(realpath "${CLI_DIR}/../custom")

VERSION=$(sed -nE 's/.*version=([0-9])\.([0-9])\.([0-9]).*/\1.\2.\3/p' fenrir.properties)
update=""

###################################################################

GREEN="\033[38;5;112m"
BLUE="\033[38;5;4m"
YELLOW="\033[38;5;214m"
RED="\033[38;5;196m"
ENDC="\033[0m"


function info {
    [ -z "$update" ] && echo -e "${BLUE}[ INFO  ]${ENDC} $*" # > /dev/tty
}

function warn {
    [ -z "$update" ] && echo -e "${YELLOW}[WARNING]${ENDC} $*" # > /dev/tty
}

function err {
    echo -e "${RED}[ ERROR ]${ENDC} $*" # > /dev/tty
}

function succ {
    [ -z "$update" ] && echo -e "${GREEN}[SUCCESS]${ENDC} $*" # > /dev/tty
}

#################################################################

if [ "$1" = "update" ]; then
    info "Updating fenrir up to version @$VERSION"
    update=true
fi

#################################################################

if [ "$(id -u)" -ne 0 ]; then
    if [ -n "$update" ]; then
        err "THIS SHOULD NOT HAVE HAPPENED! CONTACT US!"
    fi

    err "The script must be run under sudo!"
    exit 111
fi

###################################################################

[ -n "$SUDO_USER" ] && user=$SUDO_USER || user=$USER
info "Installing fenrir @$VERSION for '$user' user"

#################################################################

info "> Identifying OS.."

case "$(uname -s)" in
    Linux*)
        os_pref_home="/home"
        info ">> OS is LINUX"
    ;;
    Darwin*)
        os_pref_home="/Users"
        info ">> OS is MACOS"
    ;;
#    CYGWIN*)
#        os=Cygwin
#    ;;
#    MINGW*)
#        os=MinGw
#    ;;
#    MSYS_NT*)
#        os=MSys
#    ;;
    *)
        warn ">> Unsupported OS: '$(uname -s)'"
        warn ">> Do you agree to continue? (Potentially dangerous) [yes|no]"
        read -r op

        if [ "$op" != "yes" ]; then
            err "Terminating.."
            exit 3
        fi
    ;;
esac

#################################################################

info "> Validating environment.."

if [ -d "/etc/fenrir" ]; then
    warn ">> Directory '/etc/fenrir' already exists"
    warn ">> Remove existing '/etc/fenrir' [yes|no]"
    read -r op

    if [ "$op" = "yes" ]; then
        info ">>> Removing '/etc/fenrir'.."
        rm -fr /etc/fenrir
    else
        err "Terminating.."
        exit 3
    fi
fi

if [ -d "/var/fenrir" ]; then
    warn ">> Directory '/var/fenrir' already exists. Run uninstaller to remove it"
    warn ">> Remove existing '/var/fenrir'? [yes|no]"
    read -r op

    if [ "$op" = "yes" ]; then
        info ">>> Removing '/var/fenrir'.."
        rm -fr /var/fenrir
    else
        err "Terminating.."
        exit 3
    fi
fi

if ! type jq &> /dev/null; then
    err ">> 'jq' is not installed"
    exit 4
fi

if ! type wget &> /dev/null; then
    err ">> 'wget' is not installed"
    exit 4
fi

for cmd in "$CORE_UTILS_DIR"/*; do
    name=$(basename "$cmd")

    if type "$name" &> /dev/null; then
        location=($(type "$name")) # FIXME: SC2207

        warn ">> Command <$name> already exists: '${location[2]}'"
        warn ">> After installation it will be overridden. Continue? [yes|no]"
        read -r op

        if [ "$op" != "yes" ]; then
            err "Terminating.."
            exit 3
        fi
    fi
done

succ "> Ready to be installed!"

#################################################################

info "> Creating '/etc/fenrir'.."

mkdir -p /etc/fenrir
chown "$user" /etc/fenrir

succ "> Done"

#################################################################

info "> Creating '/var/fenrir'.."

mkdir -p /var/fenrir
chown "$user" /var/fenrir

succ "> Done"

#################################################################

info "> Installing core.."

for cmd in "$CORE_UTILS_DIR"/*; do
    name=$(basename "$cmd")

    if ! cp "$cmd" "/usr/local/bin/$name"; then
        err "Terminating.."
        exit 10
    fi
done

succ "> Done"

#################################################################

info "> Setting all configs.."

for cfg in "$CFGS_DIR"/*; do
    name=$(basename "$cfg")

    if ! {
        cp "$cfg" "/etc/fenrir/$name" &&
        chown "$user" "/etc/fenrir/$name"
    }; then
        err "Terminating.."
        exit 10
    fi
done

sudo chmod -t /tmp
jq ".version = \"$VERSION\"" "/etc/fenrir/main.json" > /tmp/INSTALL_FENRIR
cat /tmp/INSTALL_FENRIR > "/etc/fenrir/main.json"
sudo chmod +t /tmp

succ "> Done"

#################################################################

info "> Installing basic utils.."

if ! mkdir -p "$os_pref_home/$user/.fenrir/custom/walk"; then
    err "> Unable to create local storage"
    exit 189
fi

chown "$user" "$os_pref_home/$user/.fenrir"
chown "$user" "$os_pref_home/$user/.fenrir/custom"
chown "$user" "$os_pref_home/$user/.fenrir/custom/walk"

for util in "$BASIC_UTILS_DIR"/* "$BASIC_UTILS_DIR"/**/*; do
    relative_path=${util#$BASIC_UTILS_DIR/}

    if [ -d "$util" ]; then
        continue
    fi

    if ! {
        cp "$util" "$os_pref_home/$user/.fenrir/custom/$relative_path" &&
        chown "$user" "$os_pref_home/$user/.fenrir/custom/$relative_path"
    }; then
        err "Terminating.."
        exit 10
    fi
done

succ "> Done"

###################################################################

info "> Installing cli tool.."

cat "$CLI_DIR/fenrir" > "/usr/local/bin/fenrir"
chmod +x "/usr/local/bin/fenrir"

succ "> Done"

###################################################################

info "> Installing uninstaller.."

if ! {
    cp "$CLI_DIR/uninstall-fenrir" "/usr/local/bin/uninstall-fenrir" &&
    chmod +x "/usr/local/bin/uninstall-fenrir"
}; then
    err "Terminating.."
    exit 19
fi

succ "> Done"

###################################################################

succ "Installation has finished!"
