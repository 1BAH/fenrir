# shellcheck disable=SC2164
pushd "$BUILD_DIR/loki" &> /dev/null

./install.loki

if [ -n "${FENRIR_TEST_MODE}" ]; then
    cp LOKI_ASSEMBLED "${FENRIR_INSTALL_DIR}/loki"
    chmod +x "${FENRIR_INSTALL_DIR}/loki"
else
    sudo cp LOKI_ASSEMBLED "${FENRIR_INSTALL_DIR}/loki"
    sudo chmod +x "${FENRIR_INSTALL_DIR}/loki"
fi

source "${FENRIR_INSTALL_DIR}/loki"

popd &> /dev/null
