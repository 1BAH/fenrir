
out loki-prog "Inlining functions..."

( # Do not pollute the global scope: to be inlined in install-fenrir
    INLINE_FUNS_DIR="$CORE_UTILS_DIR/inline"

    for inline in "$INLINE_FUNS_DIR"/*; do
        out loki-log info "Inlining module '$inline'.."

        for util in "$CORE_UTILS_DIR"/*; do
            if ! [ -f "$util" ]; then
                continue
            fi

            file=$(basename "$inline")
            pattern="#include <$file>"

            ${sed_cmd} -i -e "/$pattern/r $inline" -e "/$pattern/d" "$util"
        done
    done
)

out loki-gorp "DONE"
