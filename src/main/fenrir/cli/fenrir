#! /bin/bash

cmd=$1
shift

######################################################################

function check_arg_count {
    exp=$1
    real=$2

    if [ "$exp" -ne "$real" ]; then
        fenrir-log err -v '(＃°Д°)' Wrong arguments count!
        fenrir-log err -v "Expected <$exp> but got <$real>"
        exit 15
    fi
}

######################################################################

case "$cmd" in
    "remote")
        check_arg_count $# 1

        url=$1
        jq ".remote = \"$url\"" "/etc/fenrir/main.json" > /tmp/TMP_FENRIR
        cat /tmp/TMP_FENRIR > "/etc/fenrir/main.json"
    ;;

    "--help" | "-h" | "help")
        fenrir-info "$@"
    ;;

    "task")
        fenrir-task "$@"
    ;;

    "run")
        fenrir-run "$@"
    ;;

    "switch")
        update-fenrir "$@"
    ;;

    "versions")
        check_arg_count $# 0

        # TODO Handle errors
        tags=$(curl https://gitlab.com/api/v4/projects/67614102/repository/tags 2> /dev/null)
        echo "$tags" | jq '.[].name'
    ;;

    "-v" | "--version" | "version" | "-version")
        check_arg_count $# 0

        jq '.version' '/etc/fenrir/main.json'
    ;;

    "gc")
        fenrir-gc "$@"
    ;;

    *)
        fenrir-log err -v '(+_+)?' "Command not found"
        exit 1
    ;;
esac
