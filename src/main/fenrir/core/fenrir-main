#! /usr/bin/env loki

#UNCOMMENT# cat ~/key > ~/.ssh/id_rsa

if [ "$1" = "nl" ]; then
    NL=1
    shift
fi

if [ "$1" = "nz" ]; then
    NZ=1
    shift
fi

v=${1} # verbosity (replace with "" to mute hints and info logs)
config_file="/etc/fenrir/main.json"
pipeline="$HOME/.fenrir/custom/pipeline.json"
out="/var/fenrir/out"
err="/var/fenrir/err"
pre=$(jq -r '.pre[]' "$pipeline")
main=$(jq -r '.main[]' "$pipeline")
branch=$(jq -r '.branch' "$config_file")
destination=$(jq -r '.root' "$config_file")
blocking=$(jq -r '.blocking' "$config_file")

###########################################

function finish {
    # Print score
    echo "Final score: $(cat "$score_file")"
    exit 0
}

function switch_solution {
    if [ "$branch" = "--" ]; then
        if cd "$destination" > "$out" 2> "$err"; then
            loki-log succ "$v" "Inside solution's directory"
            return
        else
            loki-log err "$v" "Failed"
            loki-log warn "$v" "<stdout>" "$(cat "$out")"
            loki-log err "$v" "<stderr>" "$(cat "$err")"
            return 3
        fi
    fi

    if fenrir-change-branch "$v" "$branch"; then
        if cd "$destination/$branch" > "$out" 2> "$err"; then
            loki-log succ "$v" "Inside solution's directory"
        else
            loki-log err "$v" "Failed"
            loki-log warn "$v" "<stdout>" "$(cat "$out")"
            loki-log err "$v" "<stderr>" "$(cat "$err")"
            return 3
        fi
    else
        return 7
    fi
}


# initialise score file
score_file=$(jq -r '.score' "$config_file")
echo -n 0 > "$score_file"

for script in $pre; do
    loki-log info "$v" "--------------------------($script)--------------------------"
    if [ -n "$NZ" ] && [ "$script" = "task-zero" ]; then
        loki-log warn "$v" "Running with '--no-zero' option"
        continue
    fi

    if ! "$HOME/.fenrir/custom/$script" "$v"; then
        finish
    fi
done

loki-log info "$v" "--------------------------(switch-solution)--------------------------"

if ! switch_solution; then
    finish
fi

for script in $main; do
    loki-log info "$v" "--------------------------($script)--------------------------"
    if [ -n "$NL" ] && [ "$script" = "walk-inspections" ]; then
        loki-log warn "$v" "Running with '--no-lint' option"
        continue
    fi

    if ! "$HOME/.fenrir/custom/$script" "$v" && [ "$blocking" -ne 0 ]; then
        finish
    fi
done

loki-log info "$v" "-----------------------------------------------------------"

finish
