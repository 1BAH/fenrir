#! /bin/bash

#UNCOMMENT# cat ~/key > ~/.ssh/id_rsa

repo=$1
v="-v" # verbosity (replace with "" to mute hints and info logs)
config_file="/etc/fenrir/main.json"
pipeline="$HOME/.fenrir/custom/pipeline.json"
out="/var/fenrir/out"
err="/var/fenrir/err"
pre=$(jq -r '.pre[]' "$pipeline")
main=$(jq -r '.main[]' "$pipeline")
branch=$(jq -r '.branch' "$config_file")
destination=$(jq -r '.root' "$config_file")
blocking=$(jq -r '.blocking' "$config_file")

###########################################

function finish {
    # Print score
    echo "Final score: $(cat "$score_file")"
    exit 0
}

function switch_solution {
    if fenrir-change-branch "$repo" "$v" "$branch"; then
        if cd "$destination/$branch" > "$out" 2> "$err"; then
            fenrir-log succ "$v" "Inside solution's directory"
        else
            fenrir-log err "$v" "Failed"
            fenrir-log warn "$v" "<stdout>" "$(cat "$out")"
            fenrir-log err "$v" "<stderr>" "$(cat "$err")"
            return 3
        fi
    else
        return 7
    fi
}


# initialise score file
score_file=$(jq -r '.score' "$config_file")
echo -n 0 > "$score_file"

for script in $pre; do
    fenrir-log info "$v" "--------------------------($script)--------------------------"
    if ! "$HOME/.fenrir/custom/$script" "$repo" "$v"; then
        finish
    fi
done

fenrir-log info "$v" "--------------------------(switch-solution)--------------------------"

if ! switch_solution; then
    finish
fi

for script in $main; do
    fenrir-log info "$v" "--------------------------($script)--------------------------"
    if ! "$HOME/.fenrir/custom/$script" "$repo" "$v" && [ "$blocking" -ne 0 ]; then
        finish
    fi
done

fenrir-log info "$v" "-----------------------------------------------------------"



finish
