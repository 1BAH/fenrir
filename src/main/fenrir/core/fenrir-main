#! /usr/bin/env loki

##
# Usage:
#   fenrir-main [nl]
#
# Executes task validation pipeline.
#
# Options:
#    nl     See fenrir-run '-nl' option
##

#include <shift-args>

while [ "$#" -ne 0 ]; do
    case $1 in
        "nl")
            NL=1
            shift
        ;;
    esac
done


pre=$(fenrir-read-conf -a pipeline pre)
main=$(fenrir-read-conf -a pipeline main)
task=$(fenrir-read-conf run task)
destination=$(fenrir-read-conf run root)
blocking=$(fenrir-read-conf run blocking)

# No Initial Branch tasks
if [[ "$task" =~ ^.*nib$ ]]; then
    nib_task=1
fi

###########################################

ecode=0
skip=""

function pretty_print_testname {
    name=$1
    descriptor_len=10 # '[ INFO  ] '
    name_len=${#name}
    rest=$(( LOKI_COLUMNS - descriptor_len - name_len - 2 )) # Do not forget about (, )

    loki-log info "$(loki-dup '-' $(( rest / 2 )))($name)$(loki-dup '-' $(( rest - rest / 2 )))"
}

function finalise {
    # Print score
    echo "Final score: $(cat "${SCORE_FILE}")"
    exit "$ecode"
}

function save_error_report {
    echo "      <failure><![CDATA[" >> "${REPORT_FILE}"
    cat "${CMD_FILE}" | sed -E "s/${ESC}\[[0-9;]*[mG]//g" >> "$REPORT_FILE"
    echo "      ]]></failure>" >> "${REPORT_FILE}"

    echo "      <system-out><![CDATA[" >> "${REPORT_FILE}"
    cat "${OUT_FILE}" | sed -E "s/${ESC}\[[0-9;]*[mG]//g" >> "$REPORT_FILE"
    echo "      ]]></system-out>" >> "${REPORT_FILE}"

    echo "      <system-err><![CDATA[" >> "${REPORT_FILE}"
    cat "${ERR_FILE}" | sed -E "s/${ESC}\[[0-9;]*[mG]//g" >> "$REPORT_FILE"
    echo "      ]]></system-err>" >> "${REPORT_FILE}"
}

function switch_solution {
    pretty_print_testname "switch-solution"

    if lokiw cd "$destination"; then
        loki-log succ "Inside solution's directory"
    else
        loki-log fail "Failed to change directory"
        return 3
    fi

    # No task directory => just return
    if [ -n "$nib_task" ] || [ "$task" = "local" ]; then
        return
    fi

    local curr_branch
    curr_branch=$(git rev-parse --abbrev-ref HEAD)

    if [ "$task" = "$curr_branch" ]; then
        if lokiw cd "$task"; then
            loki-log succ "Inside task's directory"
            return
        else
            loki-log fail "Cannot change directory"
            return 3
        fi
    fi

    if fenrir-change-branch "$task"; then
        if lokiw cd "$task"; then
            loki-log succ "Inside task's directory"
        else
            loki-log fail "Cannot change directory"
            return 3
        fi
    else
        return 7
    fi
}


# Initialise score file
echo -n 0 > "${SCORE_FILE}"
# Initialise report file
echo "<testsuites>" > "${REPORT_FILE}"
echo "  <testsuite name=\"${task}\">" >> "${REPORT_FILE}"

for script in $pre; do
    echo "    <testcase name=\"${script}\">" >> "${REPORT_FILE}"

    pretty_print_testname "$script"

    if [ -n "$skip" ]; then
        echo "      <skipped>Blocking execution</skipped>" >> "${REPORT_FILE}"
    else
        "$(fenrir-task-path repo)/$script" || {
            ecode=$?
            skip=YES
            save_error_report
        }
    fi

    echo "    </testcase>" >> "${REPORT_FILE}"
done

switch_solution || {
    finalise "$?"
}

linter_failed=0

for script in $main; do
    echo "    <testcase name=\"${script}\">" >> "${REPORT_FILE}"

    if [ "$script" = "walk-inspections" ]; then
        if [ -n "$NL" ]; then
            echo "      <skipped>Running with --no-lint option</skipped>" >> "${REPORT_FILE}"
            loki-log warn "Running with '--no-lint' option"
            continue
        fi

        "${FENRIR_HOME}/shared/walk-inspections" || {
            ecode=$?
            skip=YES
            linter_failed=1
            save_error_report
        }
    else
        if [ "$blocking" -ne 0 ] && [ -n "$skip" ]; then
            echo "      <skipped>Blocking execution</skipped>" >> "${REPORT_FILE}"
        else
            pretty_print_testname "$script"

            "$(fenrir-task-path repo)/$script" || {
                ecode=$?
                skip=YES
                save_error_report
            }
        fi
    fi

    echo "    </testcase>" >> "${REPORT_FILE}"
done

loki-log info "$(loki-dup '-' $(( LOKI_COLUMNS - 10 )))"


echo "  </testsuite>" >> "${REPORT_FILE}"
echo "</testsuites>" >> "${REPORT_FILE}"

if (( linter_failed == 1 )); then
    loki-log warn "Some linter inspections have failed: final score is reset to 0"
    echo -n 0 > "${SCORE_FILE}"
fi

finalise
