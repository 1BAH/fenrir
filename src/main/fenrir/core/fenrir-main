#! /usr/bin/env loki

##
# Usage:
#   fenrir-main [nl] [nz]
#
# Executes task validation pipeline.
#
# Options:
#    nl     See fenrir-run '-nl' option
#    nz     See fenrir-run '-nz' option
##

#include <shift-args>

# TODO ???
#UNCOMMENT# cat ~/key > ~/.ssh/id_rsa

if [ "$1" = "nl" ]; then
    NL=1
    shift
fi

if [ "$1" = "nz" ]; then
    NZ=1
    shift
fi

pre=$(fenrir-read-conf -a pipeline pre)
main=$(fenrir-read-conf -a pipeline main)
branch=$(fenrir-read-conf main branch)
destination=$(fenrir-read-conf main root)
blocking=$(fenrir-read-conf main blocking)

###########################################

function finalise {
    # Print score
    echo "Final score: $(cat "$score_file")"
    exit 0
}

function switch_solution {
    if [ "$branch" = "--" ]; then # Special alias for multi-branch tasks
        if lokiw cd "$destination"; then
            loki-log succ "Inside solution's directory"
            return
        else
            loki-log fail "Failed to change directory"
            return 3
        fi
    fi

    if fenrir-change-branch "$branch"; then
        if lokiw cd "$destination/$branch"; then
            loki-log succ "Inside solution's directory"
        else
            loki-log fail "Cannot change directory"
            return 3
        fi
    else
        return 7
    fi
}


# initialise score file
score_file=$(fenrir-read-conf main score)
echo -n 0 > "$score_file"

for script in $pre; do
    loki-log info "--------------------------($script)--------------------------"
    if [ "$script" = "task-zero" ]; then
        if [ -n "$NZ" ]; then
            loki-log warn "Running with '--no-zero' option"
            continue
        fi

        if ! "${FENRIR_HOME}/shared/task-zero"; then
            finalise
        fi
    else
        if ! "$(fenrir-task-path repo)/$script"; then
            finalise
        fi
    fi
done

loki-log info "--------------------------(switch-solution)--------------------------"

if ! switch_solution; then
    finalise
fi

for script in $main; do
    loki-log info "--------------------------($script)--------------------------"
    if [ "$script" = "walk-inspections" ]; then
        if [ -n "$NL" ]; then
            loki-log warn "Running with '--no-lint' option"
            continue
        fi

        if ! "${FENRIR_HOME}/shared/walk-inspections"; then
            finalise
        fi
    else
        if ! "$(fenrir-task-path repo)/$script" && [ "$blocking" -ne 0 ]; then
            finalise
        fi
    fi
done

loki-log info "-----------------------------------------------------------"

finalise
