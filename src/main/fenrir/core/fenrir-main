#! /usr/bin/env loki

##
# Usage:
#   fenrir-main [nl] [nz] [i]
#
# Executes task validation pipeline.
#
# Options:
#    nl     See fenrir-run '-nl' option
#    nz     See fenrir-run '-nz' option
#    i      See fenrir-run '-i' option
##

#include <shift-args>

# TODO ???
#UNCOMMENT# cat ~/key > ~/.ssh/id_rsa

while [ "$#" -ne 0 ]; do
    case $1 in
        "nl")
            NL=1
            shift
        ;;

        "nz")
            NZ=1
            shift
        ;;

        "i")
            INL=1
            shift
        ;;
    esac
done


pre=$(fenrir-read-conf -a pipeline pre)
main=$(fenrir-read-conf -a pipeline main)
branch=$(fenrir-read-conf run task)
destination=$(fenrir-read-conf run root)
blocking=$(fenrir-read-conf run blocking)

###########################################

function finalise {
    local ecode="$1"

    # Print score
    echo "Final score: $(cat "${SCORE_FILE}")"
    exit "$ecode"
}

function safe_run {
    local cmd=$1

    "$cmd"
    local rcode=$?

    if (( rcode != 0 )) ; then
        finalise $rcode
    fi
}

# shellcheck disable=SC2317
function switch_solution {
    if [ -n "$INL" ]; then
        loki-log warn "Inline option is on: skip switching the branch"
        return
    fi

    if [ "$branch" = "--" ]; then # Special alias for multi-branch tasks
        if lokiw cd "$destination"; then
            loki-log succ "Inside solution's directory"
            return
        else
            loki-log fail "Failed to change directory"
            return 3
        fi
    fi

    if fenrir-change-branch "$branch"; then
        if lokiw cd "$destination/$branch"; then
            loki-log succ "Inside solution's directory"
        else
            loki-log fail "Cannot change directory"
            return 3
        fi
    else
        return 7
    fi
}


# initialise score file
echo -n 0 > "${SCORE_FILE}"

for script in $pre; do
    loki-log info "--------------------------($script)--------------------------"
    if [ "$script" = "task-zero" ]; then
        if [ -n "$NZ" ]; then
            loki-log warn "Running with '--no-zero' option"
            continue
        fi

        safe_run "${FENRIR_HOME}/shared/task-zero"
    else
        safe_run "$(fenrir-task-path repo)/$script"
    fi
done

loki-log info "--------------------------(switch-solution)--------------------------"

safe_run switch_solution

for script in $main; do
    loki-log info "--------------------------($script)--------------------------"
    if [ "$script" = "walk-inspections" ]; then
        if [ -n "$NL" ]; then
            loki-log warn "Running with '--no-lint' option"
            continue
        fi

        safe_run "${FENRIR_HOME}/shared/walk-inspections"
    else
        "$(fenrir-task-path repo)/$script"
        rcode=$?

        if (( rcode != 0 )) && [ "$blocking" -ne 0 ]; then
            finalise $rcode
        fi
    fi
done

loki-log info "-----------------------------------------------------------"

finalise
