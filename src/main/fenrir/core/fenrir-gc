#! /usr/bin/env loki

######################################################################
##                         VERIFY ARGUMENTS                         ##
######################################################################

# Since we execute via 'Loki', we have to shift args
if [[ $1 == "${BASH_SOURCE[0]}" ]]; then
    shift
fi

SOFT="NO"

if [ "$1" = '-s' ]; then
    loki-log warn -v "Running in 'soft' mode"
    SOFT=""
    shift
fi

exp=0
real=$#

if [ "$exp" -ne "$real" ]; then
    loki-log err -v '(＃°Д°)' Wrong arguments count!
    loki-log err -v "Expected <$exp> but got <$real>"
    exit 15
fi

######################################################################
##                           MAIN PROGRAM                           ##
######################################################################

loki-log info -v "Removing update repo.."
rm -fr "$HOME/.fenrir/tag"

loki-log info -v "Removing tmp.."
rm -fr "$HOME/.fenrir/tmp"

[ -n "$SOFT" ] && loki-log info -v "Removing local repo.."
[ -n "$SOFT" ] && rm -fr "$HOME/.fenrir/repo"

[ -n "$SOFT" ] && loki-log info -v "Removing local configs.."
[ -n "$SOFT" ] && rm -fr "$HOME/.fenrir/cfgs"

[ -n "$SOFT" ] && loki-log info -v "Cleaning default task.."
for file in "$HOME/.fenrir/custom"/*; do
    if [ -d "$file" ]; then
        continue
    fi

    if [ "$file" = "$HOME/.fenrir/custom/task-zero" ] ||
       [ "$file" = "$HOME/.fenrir/custom/walk-inspections" ]; then
           continue
    fi

    [ -n "$SOFT" ] && rm -f "$file"
done

[ -n "$SOFT" ] && loki-log info -v "Cleaning global configs.."
for file in /etc/fenrir/*; do
    if [ "$file" = "/etc/fenrir/main.json" ] ||
       [ "$file" = "/etc/fenrir/walk.json" ] ||
       [ "$file" = "/etc/fenrir/forbidden-files.json" ]; then
           continue
    fi

    [ -n "$SOFT" ] && rm -f "$file"
done

[ -n "$SOFT" ] && loki-log info -v "Setting default configs.."

TMP=$(fenrir-tmp -v)
loki-log info -v $TMP

[ -n "$SOFT" ] && jq '.branch = "-"' "/etc/fenrir/main.json" > "$TMP/TMP_FENRIR"
[ -n "$SOFT" ] && cat "$TMP/TMP_FENRIR" > "/etc/fenrir/main.json"

[ -n "$SOFT" ] && jq '.task = "-"' "/etc/fenrir/main.json" > "$TMP/TMP_FENRIR"
[ -n "$SOFT" ] && cat "$TMP/TMP_FENRIR" > "/etc/fenrir/main.json"

loki-log succ -v "Done"
