#! /usr/bin/env loki

##
# Usage:
#   fenrir-gc [-f|--force]
#
# Removes unused files. Has two modes: SOFT and HARD. The default is 'SOFT'
# Soft:
#   - temporary files
# Hard:
#   - temporary files
#   - local repo
#   - local configs
#
# Options:
#    -f,--force     Run in 'HARD' mode.
##

######################################################################
##                         VERIFY ARGUMENTS                         ##
######################################################################

#include <shift-args>

SOFT="YES"

if [ "$1" = '-f' ] || [ "$1" = '--force' ]; then
    loki-log warn "Running in 'forced' mode"
    SOFT=""
    shift
fi

EXP_ARGC=0
#include <verify-argc>

######################################################################
##                           MAIN PROGRAM                           ##
######################################################################

loki-log info "Removing tmp.."
rm -fr "${FENRIR_TMP_DIR}"

[ -n "$SOFT" ] || loki-log info "Removing local repo.."
[ -n "$SOFT" ] || rm -fr "${FENRIR_HOME}/repo"

[ -n "$SOFT" ] || loki-log info "Removing local configs.."
[ -n "$SOFT" ] || rm -fr "${FENRIR_HOME}/cfgs"

loki-log succ "Done"
