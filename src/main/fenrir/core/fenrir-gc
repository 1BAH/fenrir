#! /usr/bin/env loki

######################################################################
##                         VERIFY ARGUMENTS                         ##
######################################################################

#include <shift-args>

HARD="YES"


if [ "$1" = '-f' ]; then
    loki-log warn "Running in 'forced' mode"
    HARD=""
    shift
fi

EXP_ARGC=0
#include <verify-argc>

######################################################################
##                           MAIN PROGRAM                           ##
######################################################################


loki-log info "Removing tmp.."
rm -fr "${FENRIR_TMP_DIR}"

# TODO -z => -n

[ -n "$HARD" ] || loki-log info "Removing local repo.."
[ -n "$HARD" ] || rm -fr "${FENRIR_HOME}/repo"

[ -n "$HARD" ] || loki-log info "Removing local configs.."
[ -n "$HARD" ] || rm -fr "${FENRIR_HOME}/cfgs"


[ -n "$HARD" ] || loki-log info "Cleaning global configs.."
for file in /etc/fenrir/*; do
    if [ "$file" = "/etc/fenrir/main.json" ] ||
       [ "$file" = "/etc/fenrir/walk.json" ] ||
       [ "$file" = "/etc/fenrir/forbidden-files.json" ]; then
           continue
    fi

    [ -n "$HARD" ] || rm -f "$file"
done

[ -n "$HARD" ] || loki-log info "Setting default configs.."


# FIXME Some old shit...
TMP=$(fenrir-tmp)
loki-log info $TMP

[ -n "$HARD" ] || jq '.branch = "-"' "/etc/fenrir/main.json" > "$TMP/TMP_FENRIR"
[ -n "$HARD" ] || cat "$TMP/TMP_FENRIR" > "/etc/fenrir/main.json"

[ -n "$HARD" ] || jq '.task = "-"' "/etc/fenrir/main.json" > "$TMP/TMP_FENRIR"
[ -n "$HARD" ] || cat "$TMP/TMP_FENRIR" > "/etc/fenrir/main.json"

loki-log succ "Done"
