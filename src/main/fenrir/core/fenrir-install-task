#! /usr/bin/env loki

##
# Usage:
#   fenrir-install-task <TASK ID>
#
# Install task by its ID from remote repo
##

LOCAL_REPO="$FENRIR_HOME/repo"
LOCAL_CFGS="$FENRIR_HOME/cfgs"

hosts=(  "$(fenrir-read-conf main remote)" )
hosts+=( $(fenrir-read-conf mirrors mirror) )

task=$1

######################################################################
##                         VERIFY ARGUMENTS                         ##
######################################################################

#include <shift-args>

EXP_ARGC=1
#include <verify-argc>

######################################################################
##                            FUNCTIONS                             ##
######################################################################

function get_url {
    filename=$1
    
    case "${TASK_HOST}" in
        https://gitlab.com*)
            echo "${TASK_HOST}/-/raw/main/${task}/${filename}"
        ;;
        https://github.com*)
            url=${TASK_HOST#"https://github.com/"}
            echo "https://raw.githubusercontent.com/${url}/refs/heads/main/${task}/${filename}"
        ;;
    esac
}

function get_file {
    url=$(get_url "$1")
    output="$LOCAL_REPO/${task}/$1"
    err_msg="Failed to download file '$1'"

    if ! lokiw curl -k -L -m 10 -o "$output" --stderr "$ERR_FILE" "$url"; then
        echo "!]" # Terminate processing line
        loki-log fail '(っ °Д °;)っ' "$err_msg"
        return 13
    else
        echo -n "*"
    fi
}

function get_index {
    if ! get_file "index.hel"; then
        return 13
    fi
}

function get_scripts {
    for script in $(fenrir-read-conf -a "${task}" scripts); do
        if ! get_file "$script"; then
            return 13
        fi

        chmod +x "$LOCAL_REPO/${task}/$script"
    done
}

function get_cfgs {
    for script in $(fenrir-read-conf -a "${task}" cfgs); do
        if ! get_file "$script"; then
            return 13
        fi
    done
}

function get_pipeline {
    if ! get_file "pipeline.hel"; then
        return 13
    fi
}

######################################################################
##                           MAIN PROGRAM                           ##
######################################################################

rm   -fr "$LOCAL_REPO/$task" "$LOCAL_CFGS/$task" # Remove old versions
succeed=0

for TASK_HOST in "${hosts[@]}"; do
    mkdir -p "$LOCAL_REPO/$task" "$LOCAL_CFGS/$task"

    loki-log info "Now using repo <${TASK_HOST}>"
    echo -e -n "$(loki-wrap "${PEACH}" DOWNLOADING) '$task' ["

    if ! get_index "$task"; then
        rm -fr "$LOCAL_REPO/$task" "$LOCAL_CFGS/$task"
        continue
    fi

    if ! get_cfgs "$task"; then
        rm -fr "$LOCAL_REPO/$task" "$LOCAL_CFGS/$task"
        continue
    fi

    if ! get_scripts "$task"; then
        rm -fr "$LOCAL_REPO/$task" "$LOCAL_CFGS/$task"
        continue
    fi

    if ! get_pipeline "$task"; then
        rm -fr "$LOCAL_REPO/$task" "$LOCAL_CFGS/$task"
        continue
    fi

    succeed=1
    break
done

if (( succeed == 1 )); then
    echo "]"
    loki-log succ '[]~(￣▽￣)~*' "Task '$task' has been downloaded"
else
    # shellcheck disable=SC2242
    exit 1984
fi
