#! /usr/bin/env loki

##
# Usage:
#   fenrir-install-task <TASK ID>
#
# Install task by its ID from remote repo
##

LOCAL_REPO="$FENRIR_HOME/repo"
LOCAL_CFGS="$FENRIR_HOME/cfgs"
TASK_HOST=$(fenrir-read-conf main remote)

task=$1

######################################################################
##                         VERIFY ARGUMENTS                         ##
######################################################################

#include <shift-args>

EXP_ARGC=1
#include <verify-argc>

######################################################################
##                            FUNCTIONS                             ##
######################################################################

function get_file {
    url=$1
    output=$2
    err_msg=$3

    if ! lokiw wget -o "$ERR_FILE" -O "$output" "$url"; then
        echo "!]" # Terminate processing line
        loki-log fail '(っ °Д °;)っ' "$err_msg"
        return 13
    else
        echo -n "*"
    fi
}

function get_index {
    if ! get_file "${TASK_HOST}/-/raw/main/${task}/index.hel" \
                  "$LOCAL_REPO/${task}/index.hel"             \
                  "Failed to download task '${task}'"
    then
        return 13
    fi
}

function get_scripts {
    for script in $(fenrir-read-conf -a "${task}" scripts); do
        if ! get_file "${TASK_HOST}/-/raw/main/${task}/$script" \
                      "$LOCAL_REPO/${task}/$script"             \
                      "Failed to download file '$script'"
        then
            return 13
        fi

        chmod +x "$LOCAL_REPO/${task}/$script"
    done
}

function get_cfgs {
    for script in $(fenrir-read-conf -a "${task}" cfgs); do
        if ! get_file "${TASK_HOST}/-/raw/main/${task}/$script" \
                      "$LOCAL_CFGS/${task}/$script"             \
                      "Failed to download file '$script'"
        then
            return 13
        fi
    done
}

function get_pipeline {
    if ! get_file "${TASK_HOST}/-/raw/main/${task}/pipeline.hel" \
                  "$LOCAL_REPO/${task}/pipeline.hel"             \
                  "Failed to download testing pipeline"
    then
        return 13
    fi
}

######################################################################
##                           MAIN PROGRAM                           ##
######################################################################

rm   -fr "$LOCAL_REPO/$task" "$LOCAL_CFGS/$task" # Remove old versions
mkdir -p "$LOCAL_REPO/$task" "$LOCAL_CFGS/$task"

echo -e -n "$(loki-wrap "${PEACH}" DOWNLOADING) '$task' ["

if ! get_index "$task"; then
    rm -fr "$LOCAL_REPO/$task" "$LOCAL_CFGS/$task"
    exit 13
fi

if ! get_cfgs "$task"; then
    rm -fr "$LOCAL_REPO/$task" "$LOCAL_CFGS/$task"
    exit 14
fi

if ! get_scripts "$task"; then
    rm -fr "$LOCAL_REPO/$task" "$LOCAL_CFGS/$task"
    exit 15
fi

if ! get_pipeline "$task"; then
    rm -fr "$LOCAL_REPO/$task" "$LOCAL_CFGS/$task"
    exit 16
fi

echo "]"

loki-log succ '[]~(￣▽￣)~*' "Task '$task' has been downloaded"
