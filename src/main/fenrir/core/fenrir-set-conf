#! /usr/bin/env loki

##
# Usage:
#   fenrir-set-conf (main|run|walk|forbidden) <PARAMETER> <VALUE>
#
# Set the value of the provided parameter in one of internal configs.
##

#include <shift-args>
#include <set-sed>

CONF_FILE="/etc/fenrir"

EXP_ARGC=3
#include <verify-argc>

case "$1" in
    run)
        CONF_FILE="${RUN_CONF_FILE}"
    ;;

    main)
        CONF_FILE="${CONF_FILE}/main.hel"
    ;;

    walk)
        CONF_FILE="${CONF_FILE}/walk.hel"
    ;;

    forbidden)
        CONF_FILE="${CONF_FILE}/forbidden-files.hel"
    ;;

    local)
        CONF_FILE="${FENRIR_HOME}/repo/local/index.hel"
    ;;

    *)
        loki-log err "Unknown conf file: '$1'"
        exit 1
    ;;
esac

# shellcheck disable=SC2154
${sed_cmd} -i "s|^${2}=.*$|${2}=\"${3}\"|" "${CONF_FILE}"
