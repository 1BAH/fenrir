#! /usr/bin/env bash

out="/var/fenrir/out"
err="/var/fenrir/err"


function local_clone {
    from=$1
    to=$(fenrir-tmp -d)

    fenrir-log info "$SILENT" "Cloning repo to '$to'.."

    if ! git clone "$from" "$to" > "$out" 2> "$err"; then
        fenrir-log err  "$SILENT" "Failed to clone locally"
        fenrir-log warn "$SILENT" "<stdout>" "$(cat "$out")"
        fenrir-log err  "$SILENT" "<stderr>" "$(cat "$err")"
        exit 56
    fi

    jq ".root = \"$to\"" "/etc/fenrir/main.json" > /tmp/TMP_FENRIR
    cat /tmp/TMP_FENRIR > "/etc/fenrir/main.json"
}

######################################################################
##                         VERIFY ARGUMENTS                         ##
######################################################################

SILENT="-v"
NO_LINT=""
NO_ZERO=""

hit=0
path=""

while [ "$#" -ne 0 ]; do
    case $1 in
        "--no-lint" | "-nl")
            NO_LINT=YES
        ;;

        "--no-zero" | "-nz")
            NO_ZERO=YES
        ;;

        "-s")
            SILENT=""
        ;;

        *)
            if [ $hit -ge 1 ]; then
                fenrir-log err "$SILENT" '(＃°Д°)' Wrong arguments count!
                fenrir-log err "$SILENT" "Expected <1> but got <$(( $# + hit ))>"
                exit 15
            fi

            path=$1

            (( hit++ ))
        ;;
    esac

    shift
done

if [ "$hit" -ne 1 ]; then
    fenrir-log err "$SILENT" '(＃°Д°)' Wrong arguments count!
    fenrir-log err "$SILENT" "Expected <1> but got <$hit>"
    exit 15
fi

######################################################################
##                           MAIN PROGRAM                           ##
######################################################################

src=$(realpath "$path")

if ! [ -d "$src/.git" ]; then
    fenrir-log err "$SILENT" '(╬▔皿▔)╯' "The provided file is not a project root"
    exit 89
fi

local_clone "$src"

if [ -n "$NO_LINT" ]; then
    if [ -n "$NO_ZERO" ]; then
        fenrir-main nl nz "$SILENT"
    else
        fenrir-main nl "$SILENT"
    fi
else
    if [ -n "$NO_ZERO" ]; then
        fenrir-main nz "$SILENT"
    else
        fenrir-main "$SILENT"
    fi
fi
