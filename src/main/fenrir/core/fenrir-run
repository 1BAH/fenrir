#! /bin/bash

out="/var/fenrir/out"
err="/var/fenrir/err"

######################################################################
##                         VERIFY ARGUMENTS                         ##
######################################################################

SILENT="-v"
NO_LINT=""
NO_ZERO=""

hit=0
path=""

while [ "$#" -ne 0 ]; do
    case $1 in
        "--no-lint" | "-nl")
            NO_LINT=YES
        ;;

        "--no-zero" | "-nz")
            NO_ZERO=YES
        ;;

        "-s")
            SILENT=""
        ;;

        *)
            if [ $hit -ge 1 ]; then
                fenrir-log err "$SILENT" '(＃°Д°)' Wrong arguments count!
                fenrir-log err "$SILENT" "Expected <1> but got <$(( $# + hit ))>"
                exit 15
            fi

            path=$1

            (( hit++ ))
        ;;
    esac

    shift
done

if [ "$hit" -ne 1 ]; then
    fenrir-log err "$SILENT" '(＃°Д°)' Wrong arguments count!
    fenrir-log err "$SILENT" "Expected <1> but got <$hit>"
    exit 15
fi

######################################################################
##                           MAIN PROGRAM                           ##
######################################################################

src=$(realpath "$path")

if ! [ -d "$src/.git" ]; then
    fenrir-log err "$SILENT" '(╬▔皿▔)╯' "The provided file is not a project root"
    exit 89
fi

jq ".root = \"$src\"" "/etc/fenrir/main.json" > /tmp/TMP_FENRIR
cat /tmp/TMP_FENRIR > "/etc/fenrir/main.json"



# Validate diff
fenrir-log info "$SILENT" "Validating diff.."
REQUIRES_ROLLBACK=""

cd "$src" || exit 14

if ! git diff-index --quiet HEAD; then
    fenrir-log warn "$SILENT" "AUTOCOMMITING CHANGES.."

    if ! git add . > "$out" 2> "$err"; then
        fenrir-log err  "$SILENT" "Failed to run 'git add'"
        fenrir-log warn "$SILENT" "<stdout>" "$(cat "$out")"
        fenrir-log err  "$SILENT" "<stderr>" "$(cat "$err")"
        exit 56
    fi

    if ! git commit -m "dummy-commit" > "$out" 2> "$err"; then
        fenrir-log err  "$SILENT" "Failed to run 'git commit'"
        fenrir-log warn "$SILENT" "<stdout>" "$(cat "$out")"
        fenrir-log err  "$SILENT" "<stderr>" "$(cat "$err")"
        exit 56
    fi

    REQUIRES_ROLLBACK=YES
fi

fenrir-log succ "$SILENT" "Done"
# End



if [ -n "$NO_LINT" ]; then
    if [ -n "$NO_ZERO" ]; then
        fenrir-main nl nz "$SILENT"
    else
        fenrir-main nl "$SILENT"
    fi
else
    if [ -n "$NO_ZERO" ]; then
        fenrir-main nz "$SILENT"
    else
        fenrir-main "$SILENT"
    fi
fi

cd "$INVOCATION_DIR"

if [ -n "$REQUIRES_ROLLBACK" ]; then
    fenrir-log warn "$SILENT" "Rolling back the changes"

    if ! git reset --mixed HEAD~1 > "$out" 2> "$err"; then
        fenrir-log err  "$SILENT" "Failed to run 'git reset': You might need to do it manually!"
        fenrir-log warn "$SILENT" "<stdout>" "$(cat "$out")"
        fenrir-log err  "$SILENT" "<stderr>" "$(cat "$err")"
        exit 56
    fi
fi
