#! /usr/bin/env loki

##
# Usage:
#   fenrir-run [-i] [-nl|--no-lint] [-c|--testcase TESTCASE] <SOLUTION DIRECTORY>
#
# Test the provided solution. The test must be set beforehand with 'fenrir-task' command.
# This command is an interface. For the detailed execution pipeline see 'fenrir-main'.
# When TESTCASE is provided, it run only the selected testcase
#
# Options:
#    -i                 Run test inside the provided directory without cloning it
#                       WARNING! In case of test's impurity it might produce some side-effects
#   -nl, --no-lint      Skip linting stage (walk-inspections)
##

function local_clone {
    from=$1
    to=$(fenrir-tmp -d)

    loki-log info "Cloning repo to '$to'.."

    if ! lokiw git clone "$from" "$to"; then
        loki-log fail '(シ. .)シ' "Failed to clone locally"
        exit 56
    fi

    fenrir-set-conf run "root" "$to"
}

######################################################################
##                         VERIFY ARGUMENTS                         ##
######################################################################

#include <shift-args>

NO_LINT=""
INLINE=""

hit=0
path=""

while [ "$#" -ne 0 ]; do
    case $1 in
        "--no-lint" | "-nl")
            NO_LINT="nl"
        ;;

        "-i")
            INLINE="i"
        ;;

        "--testcase" | "-c")
            testcase=${2?"You must select the testcase!"}
            INLINE="i"
            shift
        ;;

        -*)
            loki-log err '(＃°Д°)' Unknown flag: "<$1>"
            exit 16
        ;;

        *)
            if [ $hit -ge 1 ]; then
                loki-log err '(＃°Д°)' Wrong arguments count!
                loki-log err "Expected <1> but got <$(( $# + hit ))>"
                exit 15
            fi

            path=$1

            (( hit++ ))
        ;;
    esac

    shift
done

if [ "$hit" -ne 1 ]; then
    loki-log err '(＃°Д°)' Wrong arguments count!
    loki-log err "Expected <1> but got <$hit>"
    exit 16
fi

# Docker execution uses inline option by default
if [ -n "${FENRIR_IN_DOCKER}" ]; then
    INLINE="i"
fi

task=$(fenrir-read-conf run task)

if [ "$task" = "-" ]; then
    loki-log err 'ᕙ( •̀ ᗜ •́ )ᕗ' "The task was not set!"
    exit 89
fi

if ! [ -d "$(fenrir-task-path repo)" ]; then
    loki-log err "Task <$task> is not installed!"
    loki-log err "Install it via 'fenrir task $task' to be able to run tests"
    exit 77
fi

######################################################################
##                           MAIN PROGRAM                           ##
######################################################################

echo "$FENRIR_LOGO"

allowed_inline=$(fenrir-read-conf "$task" inline)
allowed_inline=${allowed_inline:-1}

allowed=$(fenrir-read-conf "$task" inhost)
allowed=${allowed:-1}

# Check env restrictions
if [ -z "${FENRIR_IN_DOCKER}" ]; then
    if (( allowed != 1 )); then
        loki-log err "This task does not support execution in host system"
        loki-log err "Use 'fenrir rund \"$path\"' instead"
        exit 101
    fi

    if (( allowed_inline != 1 )) && [ -n "$INLINE" ]; then
        loki-log err "This task does not support inline execution"
        loki-log err "Remove '-i' flag"
        exit 102
    fi
fi

src=$(realpath "$path")

[ -n "$INLINE" ] || if ! [ -d "$src/.git" ]; then
    loki-log err '(╬▔皿▔)╯' "The provided file is not a project root"
    exit 90
fi

if [ -n "$INLINE" ]; then
    fenrir-set-conf run "root" "$src"
else
    local_clone "$src"
fi

# shellcheck disable=SC2086
fenrir-main $NO_LINT $testcase
