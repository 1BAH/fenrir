#! /usr/bin/env loki

##
# Usage:
#   fenrir-change-branch <branch name>
#
# Checks out to the provided branch in the current solution directory
##

EXP_ARGC=1
#include <verify-argc>

branch=$1
destination=$(fenrir-read-conf run root)

##############

lokiw pushd "$destination" || {
    loki-log fail "Cannot switch to '$destination'"
    exit 7
}

loki-log info "Switching branch to '$branch'"

if lokiw git switch "$branch"; then
    loki-log succ "Switched to '$branch'"
else
    loki-log fail "Cannot check out to '$branch'"
    lokiw popd || {
        loki-log fail "Failed to pop directory"
        exit 7
    }

    exit 1
fi

lokiw popd || {
    loki-log fail "Failed to pop directory"
    exit 7
}
