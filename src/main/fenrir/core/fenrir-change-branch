#! /usr/bin/env loki

##
# Usage:
#   fenrir-change-branch <branch name>
#
# Checks out to the provided branch
##

EXP_ARGC=1
#include <verify-argc>

branch=$1
destination=$(fenrir-read-conf main root)

##############

pushd "$destination" &> /dev/null || {
    loki-log err "Cannot switch to '$destination'"
    exit 7
}

loki-log info "Switching branch to '$branch'"

if lokiw git switch "$branch"; then
    loki-log succ "Switched to '$branch'"
else
    loki-log fail "Cannot check out to '$branch'"
    popd &> /dev/null
    exit 1
fi

popd &> /dev/null
