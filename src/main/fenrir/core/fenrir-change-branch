#! /usr/bin/env loki

verbosity=$1
branch=$2
destination=$(fenrir-getroot)
out="/var/fenrir/out"
err="/var/fenrir/err"

##############

pushd "$destination" &> /dev/null

loki-log info "$verbosity" "Switching branch to '$branch'"

if git switch "$branch" > "$out" 2> "$err"
then
    loki-log succ "$verbosity" "Switched to '$branch'"
else
    loki-log err "$verbosity" "Failed"
    loki-log warn "$verbosity" "<stdout>" "$(cat "$out")"
    loki-log err "$verbosity" "<stderr>" "$(cat "$err")"
    popd &> /dev/null
    exit 1
fi

popd &> /dev/null
