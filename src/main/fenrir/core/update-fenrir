#! /bin/bash

url="https://gitlab.com/atpd/progtech/fenrir.git"
out="/var/fenrir/out"
err="/var/fenrir/err"

######################################################################
##                         VERIFY ARGUMENTS                         ##
######################################################################

DOCKER_UPDATE="-v"

if [ "$1" = "-d" ]; then
    DOCKER_UPDATE=""
    shift
fi

exp=1
real=$#

if [ "$exp" -ne "$real" ]; then
    fenrir-log err "$DOCKER_UPDATE" '(＃°Д°)' Wrong arguments count!
    fenrir-log err "$DOCKER_UPDATE" "Expected <$exp> but got <$real>"
    exit 15
fi

######################################################################
##                            FUNCTIONS                             ##
######################################################################

function safe_tag_clone {
    tag=$1

    if [ -d "$HOME/.fenrir/tag" ]; then
        rm -rf "$HOME/.fenrir/tag"
    fi

    if ! git clone --depth 1 --branch "$tag" "$url" "$HOME/.fenrir/tag" > "$out" 2> "$err"; then
        fenrir-log err  "$DOCKER_UPDATE" 'ヽ（≧□≦）ノ' "Failed to clone repo"
        fenrir-log warn "$DOCKER_UPDATE" "<stdout>" "$(cat "$out")"
        fenrir-log err  "$DOCKER_UPDATE" "<stderr>" "$(cat "$err")"
        exit 66
    fi
}

function safe_clone {
    if [ -d "$HOME/.fenrir/tag" ]; then
        rm -rf "$HOME/.fenrir/tag"
    fi

    if ! git clone --depth 1 "$url" "$HOME/.fenrir/tag" > "$out" 2> "$err"; then
        fenrir-log err  "$DOCKER_UPDATE" 'ヽ（≧□≦）ノ' "Failed to clone repo"
        fenrir-log warn "$DOCKER_UPDATE" "<stdout>" "$(cat "$out")"
        fenrir-log err  "$DOCKER_UPDATE" "<stderr>" "$(cat "$err")"
        exit 66
    fi
}

######################################################################
##                           MAIN PROGRAM                           ##
######################################################################

tag=$1

if [ "$tag" = "latest" ]; then
    safe_clone
elif [ -z "$tag" ]; then
    fenrir-log err "$DOCKER_UPDATE" '(ㆆ_ㆆ)' "Empty version"
    exit 67
else
    safe_tag_clone "$tag"
fi

if [ -z "$DOCKER_UPDATE" ]; then
    echo "$PASS" | sudo -S uninstall-fenrir docker
    echo "$PASS" | sudo -S "$HOME/.fenrir/tag/src/main/fenrir/cli/install-fenrir" docker
else
    sudo uninstall-fenrir update
    sudo "$HOME/.fenrir/tag/src/main/fenrir/cli/install-fenrir" update
fi

fenrir-log succ "$DOCKER_UPDATE" '♪(^∇^*)' "Successfully switched to $(jq '.version' '/etc/fenrir/main.json') version"
