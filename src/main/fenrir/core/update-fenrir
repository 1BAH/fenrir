#! /usr/bin/env loki

##
# Usage:
#   update-fenrir <VERSION>
#
# Automatically updates fenrir up to the selected version.
# The version is one of the existing tags (see 'fenrir versions').
# If the version is 'latest', the main branch is used.
##

url="https://gitlab.com/atpd/fenrir.git"

######################################################################
##                         VERIFY ARGUMENTS                         ##
######################################################################
#include <shift-args>

EXP_ARGC=1
#include <verify-argc>

######################################################################
##                            FUNCTIONS                             ##
######################################################################

function safe_tag_clone {
    tag=$1

    lokiw git clone --depth 1 --branch "$tag" "$url" "${clone_dir}" || {
        loki-log fail 'ヽ（≧□≦）ノ' "Failed to clone repo"
        exit 66
    }
}

function safe_clone {
    lokiw git clone --depth 1 "$url" "$HOME/.fenrir/tag" "${clone_dir}" || {
        loki-log fail 'ヽ（≧□≦）ノ' "Failed to clone repo"
        exit 66
    }
}

######################################################################
##                           MAIN PROGRAM                           ##
######################################################################

tag=$1
clone_dir=$(fenrir-tmp -d)

if [ "$tag" = "latest" ]; then
    safe_clone
elif [ -z "$tag" ]; then
    loki-log err '(ㆆ_ㆆ)' "Empty version"
    exit 67
else
    safe_tag_clone "$tag"
fi

if [ -n "${FENRIR_IN_DOCKER}" ]; then
    echo "$PASS" | sudo -S uninstall-fenrir
    echo "$PASS" | sudo -S "${clone_dir}/src/main/fenrir/cli/install-fenrir"
else
    sudo uninstall-fenrir
    sudo "${clone_dir}/src/main/fenrir/cli/install-fenrir"
fi

loki-log succ '♪(^∇^*)' "Successfully switched to $(fenrir version) version"
