#! /usr/bin/env loki

##
# Usage:
#   update-fenrir [--bash|--zsh] <VERSION>
#
# Automatically updates fenrir up to the selected version.
# The version is one of the existing tags (see 'fenrir versions').
# If the version is 'latest', the main branch is used.
#
# Options:
#    --zsh      Update autocompletion for zsh
#    --bash     Update autocompletion for bash
#
# If no option is provided, 'complete' param from main.hel is used
##

url="https://github.com/1bah/fenrir.git"

######################################################################
##                         VERIFY ARGUMENTS                         ##
######################################################################
#include <shift-args>

complete=$(fenrir-read-conf main complete)
if [ "$1" = "--bash" ]; then
    complete=--bash
    shift
elif [ "$1" = "--zsh" ]; then
    complete=--zsh
    shift
fi

EXP_ARGC=1
#include <verify-argc>

######################################################################
##                            FUNCTIONS                             ##
######################################################################

function safe_tag_clone {
    tag=$1

    lokiw git clone --depth 1 --branch "$tag" "$url" "${clone_dir}" || {
        loki-log fail 'ヽ(≧□≦)ノ' "Failed to clone repo"
        exit 66
    }
}

function safe_clone {
    lokiw git clone --depth 1 "$url" "${clone_dir}" || {
        loki-log fail 'ヽ(≧□≦)ノ' "Failed to clone repo"
        exit 66
    }
}

######################################################################
##                           MAIN PROGRAM                           ##
######################################################################

tag=$1
clone_dir=$(mktemp -d)

if [ "$tag" = "latest" ]; then
    safe_clone
elif [ -z "$tag" ]; then
    loki-log err '(ㆆ_ㆆ)' "Empty version"
    exit 67
else
    safe_tag_clone "$tag"
fi

if [ -n "${FENRIR_IN_DOCKER}" ]; then
    echo "$PASS" | sudo -S uninstall-fenrir update
    echo "$PASS" | sudo -S "${clone_dir}/src/main/fenrir/cli/install-fenrir" "$complete"
else
    sudo uninstall-fenrir update
    # shellcheck disable=SC2086
    sudo "${clone_dir}/src/main/fenrir/cli/install-fenrir" ${LOKI_VERBOSE} "$complete" # Propagate verbosity
fi

rm -fr "${clone_dir}"

loki-log succ '♪(^∇^*)' "Successfully switched to $(fenrir version) version"
