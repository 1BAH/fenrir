#! /usr/bin/env loki

TMP=$(fenrir-tmp -v)
LOCAL_REPO="$HOME/.fenrir/repo"
LOCAL_CFGS="$HOME/.fenrir/cfgs"

######################################################################
##                         PARSE ARGUMENTS                          ##
######################################################################

# Since we execute via 'Loki', we have to shift args
if [[ $1 == "${BASH_SOURCE[0]}" ]]; then
    shift
fi

INSTALL=0
DOCKER_UPDATE="-v"

if [ "$1" = "-s" ]; then
    DOCKER_UPDATE=""
    shift
fi

if [ "$1" = "-f" ] || [ "$1" = "--force" ]; then
    INSTALL=1
    shift
fi

if [ "$#" -ne "1" ]; then
    loki-log err "$DOCKER_UPDATE" '(＃°Д°)' Wrong arguments count!
    loki-log err "$DOCKER_UPDATE" "Expected <1> but got <$#>"
    exit 15
fi

TASK=$1

if ! [ -d "$LOCAL_REPO/$TASK" ]; then
    INSTALL=1
    loki-log warn "$DOCKER_UPDATE" "Task '$TASK' has not been installed yet"
else
    loki-log info "$DOCKER_UPDATE" "Task '$TASK' has already been installed"
fi

######################################################################
##                            FUNCTIONS                             ##
######################################################################

function get_local_cfgs {
    if [ "$(ls "$LOCAL_CFGS/$TASK" | wc -w)" -eq 0 ]; then
        return
    fi

    for cfg in "$LOCAL_CFGS/$TASK"/*; do
        if [ -f "/etc/fenrir/$(basename "$cfg")" ]; then
            rm -f "/etc/fenrir/$(basename "$cfg")"
        fi

        cp "$cfg" "/etc/fenrir/$(basename "$cfg")"
    done
}

function get_local_task {
    for file in "$LOCAL_REPO/$TASK"/*; do
        cp "$file" "$HOME/.fenrir/custom/$(basename "$file")"
    done
}

function set_meta {
    branch=$(jq -r .branch "$LOCAL_REPO/$TASK/index.json")
    jq ".branch = \"$branch\"" "/etc/fenrir/main.json" > "$TMP/TMP_FENRIR"
    cat "$TMP/TMP_FENRIR" > "/etc/fenrir/main.json"

    block=$(jq -r .blocking "$LOCAL_REPO/$TASK/index.json")
    jq ".blocking = \"$block\"" "/etc/fenrir/main.json" > "$TMP/TMP_FENRIR"
    cat "$TMP/TMP_FENRIR" > "/etc/fenrir/main.json"
}

######################################################################
##                           MAIN PROGRAM                           ##
######################################################################

if [ "$INSTALL" -ne 0 ]; then
    if [ -z "$DOCKER_UPDATE" ]; then
        if ! fenrir-install-task -s "$TASK"; then
            exit 56
        fi
    else
        if ! fenrir-install-task "$TASK"; then
            exit 56
        fi
    fi
fi

get_local_cfgs
get_local_task
set_meta

jq ".task = \"$TASK\"" "/etc/fenrir/main.json" > "$TMP/TMP_FENRIR"
cat "$TMP/TMP_FENRIR" > "/etc/fenrir/main.json"

loki-log succ "$DOCKER_UPDATE" '[]~(￣▽￣)~*' "Fenrir is ready to check task '$TASK'"
