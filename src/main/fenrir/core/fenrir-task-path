#! /usr/bin/env loki

##
# Usage:
#   fenrir-task-path (repo|cfgs) [task]
#
# Returns the absolute path to the task's scripts or configs.
# When [task] is empty, the current task is used.
##

LOCAL_REPO="$FENRIR_HOME/repo"
LOCAL_CFGS="$FENRIR_HOME/cfgs"

######################################################################
##                         PARSE ARGUMENTS                          ##
######################################################################

#include <shift-args>

MAX_ARGC=2
#include <verify-argc>

if (( $# == 2 )); then
    curr_task=$2
else
    curr_task=$(fenrir-read-conf run task)
fi

case "${1}" in
    "repo")
        echo "${LOCAL_REPO}/${curr_task}"
    ;;
    "cfgs")
        echo "${LOCAL_CFGS}/${curr_task}"
    ;;
    *)
        loki-log err '(+_+)?' "Parameter '$(loki-wrap "${BOLD}" "${1}")' is invalid"
        exit 67
    ;;
esac

