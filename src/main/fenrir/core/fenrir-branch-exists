#! /usr/bin/env loki

##
# Usage:
#   fenrir-branch-exists <branch name>
#
# Checks whether the provided local branch exists
##

EXP_ARGC=1
#include <verify-argc>

branch=$1

loki-log info "Checking whether branch <$branch> exists.."

if git branch | grep -q "$branch"; then
    loki-log succ "Branch exists"
else
    loki-log err "Branch does not exist"
    exit 1
fi
