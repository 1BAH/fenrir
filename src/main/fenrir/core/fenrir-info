#! /usr/bin/env loki

##
# Usage:
#   fenrir-help
#
# Show the current context of fenrir:
#   - Tasks' remote repo
#   - The task to be tested
#   - Running mode of the task (is blocking)
#   -
##

######################################################################
##                         VERIFY ARGUMENTS                         ##
######################################################################

#include <shift-args>

EXP_ARGC=0
#include <verify-argc>

######################################################################
##                           MAIN PROGRAM                           ##
######################################################################

curr_task=$(fenrir-read-conf run task)

pipeline=""
if [ -f "${FENRIR_HOME}/${curr_task}/pipeline.hel" ]; then
    pipeline=$(< "${FENRIR_HOME}/${curr_task}/pipeline.hel")
elif [ "$curr_task" != "-" ]; then
    loki-log err "Found invalid state of task '${curr_task}'. It's strongly recommended to rerun 'fenrir task ${curr_task}'."
fi

cat <<____HEREDOC
------------------------------------------------------------------
Current settings:
    * Remote: $(fenrir-read-conf main remote)
    * Current task: ${curr_task}
    * Blocking: $(fenrir-read-conf run blocking)
------------------------------------------------------------------
Run settings:
$([ -n "${pipeline}" ] && loki-wrap "${YELLOW}" "${pipeline}")
------------------------------------------------------------------
fenrir $(fenrir-read-conf main version), 2025
@_1BAH_
____HEREDOC
