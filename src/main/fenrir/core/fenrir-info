#! /usr/bin/env loki

######################################################################
##                         VERIFY ARGUMENTS                         ##
######################################################################

#include <shift-args>


EXP_ARGC=0
#include <verify-argc>

######################################################################
##                           MAIN PROGRAM                           ##
######################################################################

curr_task=$(fenrir-read-conf main task)

pipeline=""
if [ -f "${FENRIR_HOME}/${curr_task}/pipeline.hel" ]; then
    pipeline=$(< "${FENRIR_HOME}/${curr_task}/pipeline.hel")
elif [ "$curr_task" != "-" ]; then
    loki-log err "Found invalid state of task '${curr_task}'. It's strongly recommended to rerun 'fenrir task ${curr_task}'."
fi

cat <<____HEREDOC
------------------------------------------------------------------
Current settings:
    * Remote: $(fenrir-read-conf main remote)
    * Current task: ${curr_task}
    * Blocking: $(fenrir-read-conf main blocking)
    * Last installed task: $(fenrir-read-conf main task)
------------------------------------------------------------------
Run settings:
$([ -n "${pipeline}" ] && loki-wrap "${YELLOW}" "${pipeline}")
------------------------------------------------------------------
fenrir $(fenrir-read-conf main version), 2025
@_1BAH_
____HEREDOC
