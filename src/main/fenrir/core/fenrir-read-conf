#! /usr/bin/env loki

##
# Usage:
#   fenrir-read-conf [-a] (main|run|walk|forbidden|pipeline) <PARAMETER>
#
# Get the value of the provided parameter in one of internal configs.
#
# Options:
#    -a     The parameter is an array
#
# Special configs:
#    CONF_FILE    The path to the configs directory. It's HIGHLY unrecommended to change it!
#                 Default value is '/etc/fenrir'
##

CONF_FILE="/etc/fenrir"

is_array=0

if [ "$1" == "-a" ]; then
    is_array=1
    shift
fi

EXP_ARGC=2
#include <verify-argc>

case "$1" in
    run)
        CONF_FILE="${RUN_CONF_FILE}"
        ;;
    main)
        CONF_FILE="${CONF_FILE}/main.hel"
        ;;
    walk)
        CONF_FILE="${CONF_FILE}/walk.hel"
        ;;
    forbidden)
        CONF_FILE="${CONF_FILE}/forbidden-files.hel"
        ;;
    pipeline)
        task=$(fenrir-read-conf run task)
        CONF_FILE="${FENRIR_HOME}/repo/${task}/pipeline.hel"
        ;;
    *)
        CONF_FILE="$FENRIR_HOME/repo/$1"

        if ! [ -d "${CONF_FILE}" ]; then
            loki-log err "Unknown conf file: '$1'"
            exit 1
        fi

        CONF_FILE="${CONF_FILE}/index.hel"
esac


(
    # Avoid `\r\n`
    sed -i 's/\r$//' "${CONF_FILE}"

    # shellcheck disable=SC1090
    source "$CONF_FILE"

    if (( is_array == 1 )); then
        eval "echo \"\${${2}[@]}\""
    else
        eval "echo \"\$${2}\""
    fi
)
