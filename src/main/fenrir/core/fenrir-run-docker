#! /usr/bin/env loki

##
# Usage:
#   fenrir-rund [-d|--debug] [-nl|--no-lint] [-c|--testcase TESTCASE] <SOLUTION DIRECTORY>
#
# Starts a container and executes 'fenrir-run' inside.
# After the execution the container is removed unless the 'debug' flag is set.
# When TESTCASE is provided, it run only the selected testcase
#
# Options:
#    -d, --debug        Does not stop the container (allows further debug)
#   -nl, --no-lint      Skip linting stage (walk-inspections)
##

function finalise {
    local message=$1
    local ecode=${2:-0}

    loki-log fail "$message"

    if [ -n "$debug" ]; then
        loki-log err "Container exited with non-zero code: <$ecode>"
        loki-log warn "Do not forget to stop the container: 'docker stop $container'"
    else
        docker stop "$container" &> /dev/null
    fi

    exit "$ecode"
}

######################################################################
##                         VERIFY ARGUMENTS                         ##
######################################################################

#include <shift-args>

NO_LINT=""
debug=""

hit=0
path=""

while [ "$#" -ne 0 ]; do
    case $1 in
        "--no-lint" | "-nl")
            NO_LINT="-nl"
        ;;

        "--debug" | "-d")
            debug="YES"
        ;;

        "--testcase" | "-c")
            testcase=${2?"You must select the testcase!"}
            shift
        ;;

        -*)
            loki-log err '(＃°Д°)' Unknown flag: "<$1>"
            exit 16
        ;;

        *)
            if [ $hit -ge 1 ]; then
                loki-log err '(＃°Д°)' Wrong arguments count!
                loki-log err "Expected <1> but got <$(( $# + hit ))>"
                exit 15
            fi

            path=$1

            (( hit++ ))
        ;;
    esac

    shift
done

if [ "$hit" -ne 1 ]; then
    loki-log err '(＃°Д°)' Wrong arguments count!
    loki-log err "Expected <1> but got <$hit>"
    exit 16
fi

######################################################################
##                           MAIN PROGRAM                           ##
######################################################################

task=$(fenrir-read-conf run task)

if [ "$task" = "-" ]; then
    loki-log err 'ᕙ( •̀ ᗜ •́ )ᕗ' "The task was not set!"
    exit 89
fi

if ! [ -d "$(fenrir-task-path repo)" ]; then
    loki-log err "Task <$task> is not installed!"
    loki-log err "Install it via 'fenrir task $task' to be able to run tests"
    exit 77
fi

allowed=$(fenrir-read-conf "$task" indocker)
allowed=${allowed:-1}

# Check env restrictions
if (( allowed != 1 )); then
    loki-log err "This task does not support execution in docker"
    loki-log err "Use 'fenrir run $task' instead"
    exit 103
fi

src=$(realpath "$path")

image=$(fenrir-read-conf "$task" image)
image=${image:-"registry.gitlab.com/atpd/fenrir/fenrir-base:latest"}

lokiw docker pull "$image" || {
    loki-log warn "Cannot update image.. Trying to use a cached one instead.."
}

container=$(docker run -e LOKI_VERBOSE --rm -d "$image" 2> "${ERR_FILE}")
status=$?

if (( status != 0 )); then
    loki-log fail "Cannot start docker"
    exit $status
fi

loki-log info "Running on: " "$(docker exec -it "$container" fenrir v)"

lokiw docker exec -it "$container" fenrir info || {
    finalise "Failed to find 'fenrir' in container" "$?"
}

lokiw docker cp "$src" "$container:/home/fikus/solution" || {
    finalise "Unable to copy solution into container" "$?"
}

lokiw docker cp "$FENRIR_HOME" "$container:/home/fikus" || {
    finalise "Unable to copy local repo into container" "$?"
}

lokiw docker exec -u root "$container" chown fikus -R "/home/fikus" || {
    finalise "Unable to change owner" "$?"
}

lokiw docker cp "$RUN_CONF_FILE" "$container:/tmp/fenrir/tmp/run-conf.hel" || {
    finalise "Unable to copy run-conf into container" "$?"
}

lokiw docker exec -u root "$container" chown fikus -R "/tmp/fenrir" || {
    finalise "Unable to change owner" "$?"
}

if [[ -v testcase ]]; then
    docker exec -it "$container" bash -c "cd solution && fenrir run -i -c ${testcase} ${NO_LINT} ."
    ecode=$?
else
    docker exec -it "$container" bash -c "cd solution && fenrir run -i ${NO_LINT} ."
    ecode=$?
fi

if (( ecode == 0 )); then
    docker stop "$container" &> /dev/null
elif [ -n "$debug" ]; then
    loki-log err "Container exited with non-zero code: <$ecode>"
    loki-log warn "Do not forget to stop the container: 'docker stop $container'"
else
    loki-log err "Container exited with non-zero code: <$ecode>"
    docker stop "$container" &> /dev/null
fi

exit "$ecode"
