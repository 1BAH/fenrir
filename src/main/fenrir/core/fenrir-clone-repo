#! /usr/bin/env loki

repo=$1
destination="$HOME/solution"

##############

loki-log info "Cloning repo $repo"

if [ -d "$destination" ]; then
    loki-log warn "Remove previously cloned repo"
    rm -fr "$destination"
fi

if lokiw git clone "$repo" "$destination"
then
    loki-log succ "Cloned repo to directory 'solution'"
else
    loki-log fail "Cannot clone the repository"
    exit 1
fi

pushd "$destination" &> /dev/null
git switch task0 &> /dev/null
git switch "$(fenrir-read-conf main branch)" &> /dev/null

# FIXME get rid of jq
if [ "$(jq -r '.task' "/etc/fenrir/main.json")" = "git/ess" ]; then
    for i in $(seq 1 17); do
        git switch $i &> /dev/null
    done
fi
pod &> /dev/null

