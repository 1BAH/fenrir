#! /usr/bin/env loki

repo=$1
destination=$(fenrir-read-conf run root)

######################################################################
##                         VERIFY ARGUMENTS                         ##
######################################################################

#include <shift-args>

EXP_ARGC=1
#include <verify-argc>

######################################################################
##                           MAIN PROGRAM                           ##
######################################################################

loki-log info "Cloning repo $repo"

if [ -d "$destination" ]; then
    loki-log warn "Removing previously cloned repo.."
    rm -fr "$destination"
fi

if lokiw git clone "$repo" "$destination"; then
    loki-log succ "Cloned repo to directory 'solution'"
else
    loki-log fail "Cannot clone the repository"
    exit 1
fi

