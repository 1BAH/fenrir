#! /usr/bin/env bash

first=1

for part in loki-common-*; do
    pattern="#include <$part>"

    if (( first == 1 )); then
        sed -e "/$pattern/r $part" -e "/$pattern/d" loki > /tmp/FENRIR_HEADER
        first=0
    else
        sed -i -e "/$pattern/r $part" -e "/$pattern/d" /tmp/FENRIR_HEADER
    fi
done
