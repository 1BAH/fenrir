#! /bin/bash

file=$1

fenrir-log info "$2" "NLI: Inspecting '$file'"

if [[ $file == *.png ]]; then
    fenrir-log info "$2" "NLI: Skipping image"
    exit 0
fi

if [[ $file == *.jpg ]]; then
    fenrir-log info "$2" "NLI: Skipping image"
    exit 0
fi

if [[ $file == *.jpeg ]]; then
    fenrir-log info "$2" "NLI: Skipping image"
    exit 0
fi

if [[ $file == *.svg ]]; then
    fenrir-log info "$2" "NLI: Skipping image"
    exit 0
fi

last_sym=$(tail -c 1 "$file")

if [ -n "$last_sym" ]; then
    fenrir-log err "$2" "NLI: File '$file' has no EOL at the end."
    exit 3
fi
