#! /usr/bin/env loki

verbosity=$1
destination=$(fenrir-getroot)
out="/var/fenrir/out"
err="/var/fenrir/err"

##############

loki-log info "$verbosity" "TZ: Validating task0"

if fenrir-change-branch "$verbosity" "task0"; then
    if pushd "$destination/task0" > "$out" 2> "$err"; then
        if [ -x "run.sh" ]; then
            loki-log succ "$verbosity" "TZ: task0 is completed"
            exit 0 # successful exit
        else
            loki-log err "$verbosity" "TZ: File 'run.sh' does not exist or is not executable"
        fi
    else
        loki-log err "$verbosity" "TZ: Failed"
        loki-log warn "$verbosity" "<stdout>" "$(cat "$out")"
        loki-log err "$verbosity" "<stderr>" "$(cat "$err")"
    fi
fi

loki-log err "$verbosity" "TZ: Validation failed"
exit 3
