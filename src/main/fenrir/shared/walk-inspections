#! /usr/bin/env loki

config="/etc/fenrir/walk.json"

loki-log info "WI: Start"

root_dir=$(fenrir-read-conf main root)

declare -A skip_list

for item in $(fenrir-read-conf -a walk skip); do
    skip_list+=( ["$item"]=1 )
done

function terminate {
    loki-log err "WI: terminate"
    exit 3
}

function dir_check {
    local dir=$1

    if ! [[ ${skip_list[$(basename "$dir")]+_} ]]; then
        for inspection in $(fenrir-read-conf -a walk dirs); do
            if ! "$HOME/.fenrir/custom/walk/$inspection" "$dir"; then
                terminate
            fi
        done

        inspect_dir "$dir"
    fi
}

function inspect_dir {
    local dir=$1

    for file in "$dir"/* "$dir"/.*; do
        if [ -f "$file" ]; then
            for inspection in $(fenrir-read-conf walk -a files); do
                if ! "$HOME/.fenrir/custom/walk/$inspection" "$file"; then
                    terminate
                fi
            done
        else
            if [ -d "$file" ]; then
                dir_check "$file"
            fi
        fi
    done
}

loki-log succ "WI: All inspections have passed"
