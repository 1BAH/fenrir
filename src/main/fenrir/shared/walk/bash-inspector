#! /usr/bin/env loki

# WARNING! Requires shellcheck to be installed!

if ! type shellcheck &> /dev/null; then
    loki-log err "shellcheck is not installed"
fi

file=$1

if ! [[ $file == *.sh ]]; then
    exit 0
fi


loki-log info "BI: Inspecting '$file'"

if [ "$LOKI_VERBOSE" == "-v" ]; then
    if ! shellcheck -a -Calways "$file" ; then
        loki-log err "BI: File '$file' contains violations."
        exit 2
    fi
else
    if ! shellcheck -a -Cnever "$file" ; then
        loki-log err "BI: File '$file' contains violations."
        exit 3
    fi
fi
