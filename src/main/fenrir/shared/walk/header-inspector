#! /usr/bin/env loki

file=$1

if ! [[ $file == *.h || $file == *.hh || $file == *.hpp ||
        $file == *.H || $file == *.hxx || $file == *.hp ||
        $file == *.c || $file == *.cc || $file == *.cpp ||
        $file == *.C || $file == *.cxx || $file == *.cp ]]; then
    exit 0
fi

loki-log info "HI: Inspecting '$file'"

if grep -q '#include <\.' "$file"; then
    loki-log err "HI: File '$file' contains a relative include."
    exit 21
fi

if grep -q '#include "\.' "$file"; then
    loki-log err "HI: File '$file' contains a relative include."
    exit 22
fi

