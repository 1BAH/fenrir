#! /usr/bin/env loki

loki-set-log-prefix "FDI: "

loki-log info "Inspecting '$1'"

name=$(basename "$1")

declare -A forbidden_dirs
for item in $(fenrir-read-conf -a forbidden directories); do
    forbidden_dirs+=( ["$item"]=1 )
done

if [[ ${forbidden_dirs[$name]+_} ]]; then
    loki-log err "Found forbidden directory: '$1'"
    exit 4
fi

lokiw pushd "$1" || {
   loki-log fail "Failed to push directory"
   exit 7
}

for pattern in $(fenrir-read-conf -a forbidden filePatterns); do
    if lokiw ls "$pattern"; then
        loki-log fail "Found forbidden file pattern: '$pattern'"

        lokiw popd || {
            loki-log fail "Failed to push directory"
        }
        exit 3
    fi
done

lokiw popd || {
    loki-log fail "Failed to pop directory"
    exit 7
}
